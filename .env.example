# AI SDLC Team - Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control

# ============================================================================
# ANTHROPIC API
# ============================================================================
# Get your API key from https://console.anthropic.com/account/keys
# Required for all Claude API calls across all agents
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ============================================================================
# DATABASE (Optional - for persistent context store)
# ============================================================================
# Currently using file-based storage. For production, connect to database.
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_sdlc_team
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# GITHUB INTEGRATION (Optional - for PR creation and reviews)
# ============================================================================
# Get token from https://github.com/settings/tokens
# Needs: repo, workflow, gist scopes
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repository-name

# ============================================================================
# DESIGN SYSTEM INTEGRATION (Optional - for UX Agent)
# ============================================================================
# Figma API for design token access
FIGMA_API_TOKEN=your-figma-token-here
FIGMA_FILE_ID=your-figma-file-id-here

# Storybook for component library reference
STORYBOOK_URL=https://storybook.your-company.com

# ============================================================================
# COMMUNICATION (Optional - for notifications)
# ============================================================================
# Slack for workflow notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#ai-sdlc-notifications

# Email for reports
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=ai-sdlc-team@your-company.com

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Sentry for error tracking (optional)
SENTRY_DSN=

# Datadog or other APM (optional)
DATADOG_API_KEY=
DATADOG_APP_KEY=

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Team name for this instance
TEAM_NAME=Default Team

# Enable demo mode (uses simulated workflows)
DEMO_MODE=false

# Enable verbose logging
VERBOSE=false

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================
# Claude model to use across all agents
CLAUDE_MODEL=claude-sonnet-4-20250514

# Temperature for LLM (0.0-1.0, higher = more creative)
CLAUDE_TEMPERATURE=0.7

# Max tokens per request
CLAUDE_MAX_TOKENS=2048

# ============================================================================
# PATHS & STORAGE
# ============================================================================
# Context store path for artifacts
CONTEXT_STORE_PATH=team_contracts/context-store

# Working directory for generated files
WORK_DIR=./ai_sdlc_work

# Temporary directory for intermediate files
TEMP_DIR=/tmp/ai_sdlc

# ============================================================================
# EXTERNAL SERVICES (Optional)
# ============================================================================
# Jira for issue tracking
JIRA_URL=https://jira.your-company.com
JIRA_USERNAME=your-jira-username
JIRA_API_TOKEN=your-jira-api-token

# Linear for alternative issue tracking
LINEAR_API_KEY=your-linear-api-key

# OpenAI (for fallback or comparison)
OPENAI_API_KEY=sk-your-openai-key-here

# ============================================================================
# TESTING & DEVELOPMENT
# ============================================================================
# Test database URL (for running tests)
TEST_DATABASE_URL=sqlite:///:memory:

# Mock external services in tests
MOCK_EXTERNAL_SERVICES=true

# Random seed for reproducible test runs
RANDOM_SEED=42

# ============================================================================
# SECURITY
# ============================================================================
# JWT secret for API authentication
JWT_SECRET=your-jwt-secret-key-here

# API key for securing orchestrator endpoints
ORCHESTRATOR_API_KEY=your-orchestrator-api-key-here

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable specific features
FEATURE_SECURITY_REVIEW=true
FEATURE_ACCESSIBILITY_CHECK=true
FEATURE_PERFORMANCE_ANALYSIS=true
FEATURE_CODE_REVIEW=true

# Early exit on security failures
SECURITY_FAIL_FAST=true

# ============================================================================
# NOTIFICATION SETTINGS
# ============================================================================
# Send notifications on workflow events
NOTIFY_ON_WORKFLOW_START=false
NOTIFY_ON_WORKFLOW_COMPLETE=true
NOTIFY_ON_WORKFLOW_FAILURE=true
NOTIFY_ON_CHECKPOINT=true

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================
# Number of retries for API calls
MAX_RETRIES=3

# Timeout for API calls (seconds)
API_TIMEOUT=30

# Number of worker processes for parallel execution
WORKER_PROCESSES=4

# Enable caching of API responses
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600
